# eslint-plugin-jsx-a11y hasn't widened its peer range to ESLint 10 yet (it
# works fine with the flat config). Relax peer resolution so installs are
# reproducible across machines and CI.
legacy-peer-deps=true

# Always record exact versions in package.json (no ^/~) so dependency upgrades
# are deliberate, not incidental.
save-exact=true

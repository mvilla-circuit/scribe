{
  "name": "scribe",
  "private": true,
  "version": "0.1.0",
  "description": "A minimalist, zen desktop writing app.",
  "author": "Marissa Villanueva",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvilla-circuit/scribe.git"
  },
  "homepage": "https://github.com/mvilla-circuit/scribe#readme",
  "bugs": {
    "url": "https://github.com/mvilla-circuit/scribe/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:circular": "madge --circular src",
    "lint:deadcode": "knip",
    "audit:deps": "npm audit --audit-level=high",
    "verify": "npm run typecheck && npm run lint && npm run lint:circular && npm run lint:deadcode && npm run format:check && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --check --manifest-path src-tauri/Cargo.toml",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --locked -- -D warnings",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0 --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,css,md}": [
      "prettier --write"
    ],
    "*.rs": [
      "rustfmt --edition 2021"
    ]
  },
